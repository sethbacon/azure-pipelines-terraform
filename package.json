{
    "name": "Terraform",
    "version": "1.0.0",
    "description": "",
    "scripts": {
        "clean": "rimraf ./build",
        "build:release": "npm run clean && npm run deps && npm run compile && npm run deps:prune && webpack",
        "package:self": "tfx extension create --rev-version --manifest-globs azure-devops-extension.json task.json --overrides-file ./configs/self.json --root ./build",
        "package:dev": "tfx extension create --rev-version --manifest-globs azure-devops-extension.json task.json --overrides-file ./configs/dev.json --root ./build",
        "package:test": "tfx extension create --manifest-globs azure-devops-extension.json --overrides-file ./configs/test.json --root ./build",
        "package:release": "tfx extension create --manifest-globs azure-devops-extension.json --overrides-file ./configs/release.json --root ./build",
        "deps": "node scripts/for-each-task.js ci",
        "deps:prune": "node scripts/for-each-task.js prune",
        "compile": "node scripts/for-each-task.js compile",
        "webpack": "webpack --config webpack.config.js --progress",
        "test:v5": "cd Tasks/TerraformTask/TerraformTaskV5 && npm test",
        "test:tab": "jest --config jest.config.js"
    },
    "devDependencies": {
        "@cyclonedx/cyclonedx-npm": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "azure-devops-extension-api": "^4.245.1",
        "azure-devops-extension-sdk": "^4.0.2",
        "azure-devops-node-api": "^12.0.0",
        "azure-pipelines-task-lib": "^5.2.8",
        "azure-pipelines-tool-lib": "^2.0.12",
        "copy-webpack-plugin": "^14.0.0",
        "css-loader": "^6.7.3",
        "jest": "^30.3.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "rimraf": "^5.0.0",
        "style-loader": "^3.3.2",
        "tfx-cli": "0.23.2",
        "ts-jest": "^29.4.9",
        "ts-loader": "^9.5.0",
        "tslib": "^2.6.0",
        "typescript": "^5.0.0",
        "webpack": "^5.88.0",
        "webpack-cli": "^5.1.0"
    },
    "overrides": {
        "uuid": "13.0.2",
        "@babel/core": "^7.29.7",
        "underscore": "^1.13.8",
        "semver": "^7.8.5",
        "js-yaml": "^4.2.0"
    }
}