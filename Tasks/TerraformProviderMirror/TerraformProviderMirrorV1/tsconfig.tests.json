{
    "compilerOptions": {
        "target": "ES6",
        "module": "commonjs",
        "skipLibCheck": true,
        "strict": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "noEmit": true
    },
    "include": [
        "Tests/**/*",
        "src/**/*"
    ]
}
